<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Spinner
            android:id="@+id/sp_time_range"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/list_item_bg"
            android:layout_marginEnd="4dp"
            android:layout_weight="1" />

        <Spinner
            android:id="@+id/sp_data_source"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/list_item_bg"
            android:layout_marginStart="4dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:weightSum="6">

        <Button
            android:id="@+id/btn_filter_all"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_radius_black_transparents"
            android:text="@string/all"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btn_filter_monster"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_radius_black_transparents"
            android:text="@string/cat_monster"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btn_filter_spell"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_radius_black_transparents"
            android:text="@string/cat_spell"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btn_filter_trap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_radius_black_transparents"
            android:text="@string/cat_trap"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btn_filter_ex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_radius_black_transparents"
            android:text="@string/cat_extra"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btn_filter_side"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/button_radius_black_transparents"
            android:padding="8dp"
            android:text="@string/cat_side"
            android:textSize="10sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/srl_refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_card_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="8dp" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂无数据"
            android:textColor="@color/grayLight"
            android:textSize="16sp"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>