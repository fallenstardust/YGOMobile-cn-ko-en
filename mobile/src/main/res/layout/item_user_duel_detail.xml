<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_detail_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/holo_green_bright"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="@color/klein_blue" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="竞技场数据"
        android:textColor="@color/holo_blue_bright"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D.P: "
            android:textColor="@color/grayLight"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_detail_pt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/holo_blue_bright"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="竞技排名: "
            android:textColor="@color/grayLight"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_detail_arena_rank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/holo_blue_bright"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.king.view.circleprogressview.CircleProgressView
            android:id="@+id/cpv_detail_athletic_wl_ratio"
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:cpvLabelTextColor="@color/white"
            app:cpvLabelTextSize="12sp"
            app:cpvNormalColor="@color/klein_blue"
            app:cpvProgressColor="@color/colorAccent"
            app:cpvShowTick="false"
            app:cpvStrokeWidth="5dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="胜: "
                    android:textColor="@color/grayLight"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_detail_athletic_win"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/holo_green_bright"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="负: "
                    android:textColor="@color/grayLight"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_detail_athletic_lose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/holo_orange_bright"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="平: "
                    android:textColor="@color/grayLight"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_detail_athletic_draw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/grayLight"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="总: "
                    android:textColor="@color/grayLight"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_detail_athletic_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="@color/klein_blue" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="娱乐场数据"
        android:textColor="@color/gold_light"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E.X.P: "
            android:textColor="@color/grayLight"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_detail_exp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gold_light"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="娱乐排名: "
            android:textColor="@color/grayLight"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_detail_exp_rank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gold_light"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="胜: "
            android:textColor="@color/grayLight"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_detail_entertain_win"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/holo_green_bright"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="负: "
            android:textColor="@color/grayLight"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_detail_entertain_lose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/holo_orange_bright"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="平: "
            android:textColor="@color/grayLight"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_detail_entertain_draw"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/grayLight"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="总: "
            android:textColor="@color/grayLight"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_detail_entertain_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="@color/klein_blue" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PT变化趋势"
        android:textColor="@color/holo_blue_bright"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_history_20"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@color/holo_blue_bright"
            android:minWidth="50dp"
            android:paddingHorizontal="10dp"
            android:text="20场"
            android:textColor="@color/black"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_history_50"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:minWidth="50dp"
            android:paddingHorizontal="10dp"
            android:text="50场"
            android:textColor="@color/grayLight"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_history_100"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:minWidth="50dp"
            android:paddingHorizontal="10dp"
            android:text="100场"
            android:textColor="@color/grayLight"
            android:textSize="12sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ProgressBar
            android:id="@+id/pb_chart_loading"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:visibility="gone" />
    </LinearLayout>

    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/chart_pt_history"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="8dp" />

</LinearLayout>
