<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/fl_head"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="5dp"
        android:background="@drawable/dialogshort"
        android:orientation="horizontal"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/ll_head_login"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="right"
            android:background="@drawable/list_item_bg"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="5dp"
                android:orientation="vertical">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|right"
                    android:text="@string/login_mycard"
                    android:textColor="@color/holo_green_bright"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="bottom|right"
                    android:background="@drawable/selected_light"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp">

                    <ProgressBar
                        android:id="@+id/pb_loading"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center|right"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/iv_refresh"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center|right"
                        android:src="@drawable/ic_refresh"
                        android:visibility="visible" />

                    <TextView
                        android:id="@+id/tv_dp_title"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center|right"
                        android:textColor="@color/holo_blue_bright"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_head"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_gravity="center"
                android:layout_marginHorizontal="5dp"
                android:src="@drawable/avatar"
                android:clickable="true"
                android:focusable="true" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_logout"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="right"
                android:src="@drawable/baseline_login_24" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:background="@drawable/list_item_bg"
            android:orientation="vertical"
            android:padding="5dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btn_mycard_bbs"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_forum"
                android:tint="@color/holo_blue_bright"
                android:visibility="visible" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_mycard_bbs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/mycard_bbs"
                android:textSize="8sp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <LinearLayout
                android:id="@+id/ll_main_ui"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:id="@+id/ll_dialog_login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:background="@drawable/dialogshort"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="4dp"
                            android:src="@drawable/mycard" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/login_mycard"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="vertical">

                        <EditText
                            android:id="@+id/et_username"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/selected_light"
                            android:hint="@string/input_user_name"
                            android:inputType="text"
                            android:padding="5dp"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tv_account_warning"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/account_warning"
                            android:textColor="@color/red"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="vertical">

                        <EditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/selected_light"
                            android:hint="@string/input_pwd"
                            android:inputType="textPassword"
                            android:padding="5dp"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tv_pwd_warning"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/pwd_warning"
                            android:textColor="@color/red"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/btn_register"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/list_item_bg"
                            android:text="@string/register" />

                        <Button
                            android:id="@+id/btn_login"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/list_item_bg"
                            android:text="@string/login_mycard" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressBar_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="11"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/rank_and_match_container"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/dialogshort"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/veil2"
                                    android:gravity="center"
                                    android:text="@string/title_rank_start"
                                    android:textColor="@color/holo_green_bright"
                                    android:textSize="8sp"
                                    android:textStyle="bold" />


                                <LinearLayout
                                    android:id="@+id/ll_athletic"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_margin="2dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/list_item_bg"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginVertical="4dp"
                                        android:orientation="horizontal">

                                        <com.king.view.circleprogressview.CircleProgressView
                                            android:id="@+id/match_cpv_rank"
                                            android:layout_width="60dp"
                                            android:layout_height="40dp"
                                            android:layout_centerVertical="true"
                                            app:cpvLabelTextColor="@color/white"
                                            app:cpvLabelTextSize="12sp"
                                            app:cpvNormalColor="@color/klein_blue"
                                            app:cpvProgressColor="@color/colorAccent"
                                            app:cpvShowTick="false"
                                            app:cpvStrokeWidth="5dp" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:layout_margin="2dp"
                                            android:text="@string/match_start"
                                            android:textColor="@color/gold_light"
                                            android:textSize="12sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <ImageView
                                            android:layout_width="14dp"
                                            android:layout_height="14dp"
                                            android:src="@drawable/ic_rank" />

                                        <TextView
                                            android:id="@+id/match_tv_rank"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginHorizontal="4dp"
                                            android:text="- - - - -"
                                            android:textColor="@color/gold_light"
                                            android:textSize="9sp" />

                                        <ImageView
                                            android:layout_width="14dp"
                                            android:layout_height="14dp"
                                            android:src="@drawable/ic_right" />

                                        <TextView
                                            android:id="@+id/match_tv_win"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginHorizontal="4dp"
                                            android:text="----"
                                            android:textColor="@color/gold_light"
                                            android:textSize="9sp" />

                                        <ImageView
                                            android:layout_width="14dp"
                                            android:layout_height="14dp"
                                            android:src="@drawable/ic_failed" />

                                        <TextView
                                            android:id="@+id/match_tv_lose"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginHorizontal="4dp"
                                            android:text="----"
                                            android:textColor="@color/gold_light"
                                            android:textSize="9sp" />

                                        <ImageView
                                            android:layout_width="14dp"
                                            android:layout_height="14dp"
                                            android:src="@drawable/ic_draw" />

                                        <TextView
                                            android:id="@+id/match_tv_draw"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginHorizontal="4dp"
                                            android:text="----"
                                            android:textColor="@color/gold_light"
                                            android:textSize="9sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal"
                                        android:visibility="gone">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="总"
                                            android:textColor="@color/white"
                                            android:textSize="9sp" />

                                        <TextView
                                            android:id="@+id/match_tv_all"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginLeft="2dp"
                                            android:text="-----"
                                            android:textColor="@color/white"
                                            android:textSize="9sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/ll_entertain"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_margin="2dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/list_item_bg"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginVertical="4dp"
                                        android:gravity="center"
                                        android:orientation="horizontal">

                                        <com.king.view.circleprogressview.CircleProgressView
                                            android:id="@+id/fun_cpv_rank"
                                            android:layout_width="60dp"
                                            android:layout_height="40dp"
                                            android:layout_centerVertical="true"
                                            android:visibility="gone"
                                            app:cpvLabelTextColor="@color/white"
                                            app:cpvLabelTextSize="12sp"
                                            app:cpvNormalColor="@color/klein_blue"
                                            app:cpvProgressColor="@color/colorAccent"
                                            app:cpvShowTick="false"
                                            app:cpvStrokeWidth="5dp" />

                                        <ImageView
                                            android:layout_width="60dp"
                                            android:layout_height="40dp"
                                            android:src="@drawable/ic_match_entertain" />

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"

                                            android:orientation="vertical">

                                            <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_margin="2dp"
                                                android:text="@string/fun_start"
                                                android:textColor="@color/white"
                                                android:textSize="12sp"
                                                android:textStyle="bold" />

                                            <LinearLayout
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_gravity="bottom"
                                                android:orientation="horizontal">

                                                <ImageView
                                                    android:layout_width="14dp"
                                                    android:layout_height="14dp"
                                                    android:src="@drawable/ic_rank" />

                                                <TextView
                                                    android:id="@+id/fun_tv_rank"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:layout_marginHorizontal="4dp"
                                                    android:text="- - - - -"
                                                    android:textColor="@color/white"
                                                    android:textSize="9sp" />
                                            </LinearLayout>
                                        </LinearLayout>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal"
                                        android:visibility="gone">

                                        <ImageView
                                            android:layout_width="14dp"
                                            android:layout_height="14dp"
                                            android:src="@drawable/ic_right" />

                                        <TextView
                                            android:id="@+id/fun_tv_win"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginHorizontal="4dp"
                                            android:text="----"
                                            android:textColor="@color/holo_blue_bright"
                                            android:textSize="9sp" />

                                        <ImageView
                                            android:layout_width="14dp"
                                            android:layout_height="14dp"
                                            android:src="@drawable/ic_failed" />

                                        <TextView
                                            android:id="@+id/fun_tv_lose"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginHorizontal="4dp"
                                            android:text="----"
                                            android:textColor="@color/holo_blue_bright"
                                            android:textSize="9sp" />

                                        <ImageView
                                            android:layout_width="14dp"
                                            android:layout_height="14dp"
                                            android:src="@drawable/ic_draw" />

                                        <TextView
                                            android:id="@+id/fun_tv_draw"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginHorizontal="4dp"
                                            android:text="----"
                                            android:textColor="@color/holo_blue_bright"
                                            android:textSize="9sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal"
                                        android:visibility="gone">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="总"
                                            android:textColor="@color/white"
                                            android:textSize="9sp" />

                                        <TextView
                                            android:id="@+id/fun_tv_all"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginLeft="2dp"
                                            android:text="- - - - -"
                                            android:textColor="@color/white"
                                            android:textSize="9sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="5dp"
                                android:layout_weight="1"
                                android:background="@drawable/dialogshort"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:layout_marginBottom="8dp"
                                    android:background="@drawable/veil2"
                                    android:gravity="center"
                                    android:text="@string/arena"
                                    android:textColor="@color/holo_green_bright"
                                    android:textSize="8sp"
                                    android:textStyle="bold" />

                                <FrameLayout
                                    android:id="@+id/fl_pie_chart_container"
                                    android:layout_width="wrap_content"
                                    android:layout_height="150dp">

                                    <cn.garymb.ygomobile.ui.widget.DeckPieChartView
                                        android:id="@+id/pie_chart_view"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content" />

                                    <TextView
                                        android:id="@+id/tv_empty"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:text="暂无数据"
                                        android:textColor="@color/gray"
                                        android:textSize="10sp"
                                        android:visibility="gone" />
                                </FrameLayout>

                                <FrameLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="12dp"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:gravity="center"
                                        android:text="@string/tips_click_to_arena"
                                        android:textSize="6sp" />

                                    <Switch
                                        android:id="@+id/sw_toggle_card_image"
                                        style="@style/CustomSwitch"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center|right"
                                        android:scaleX="0.5"
                                        android:scaleY="0.5" />
                                </FrameLayout>
                            </LinearLayout>
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="5dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/dialogshort"
                                android:orientation="vertical">

                                <com.google.android.material.tabs.TabLayout
                                    android:id="@+id/tablayout_mycard"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    app:tabTextAppearance="@style/wallet_third_tab_layout" />

                                <LinearLayout
                                    android:id="@+id/ll_mycard_waiting_rooms"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:visibility="gone">

                                    <LinearLayout
                                        android:id="@+id/ll_create_room"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginVertical="5dp"
                                        android:background="@drawable/list_item_bg"
                                        android:gravity="center"
                                        android:orientation="horizontal">

                                        <ImageView
                                            android:layout_width="20dp"
                                            android:layout_height="20dp"
                                            android:layout_gravity="center_vertical"
                                            android:layout_margin="5dp"
                                            android:src="@drawable/ic_add" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:text="@string/create_custom_room"
                                            android:textSize="12sp" />
                                    </LinearLayout>

                                    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                                        android:id="@+id/srl_waiting"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent">

                                        <cn.garymb.ygomobile.ui.widget.GridRecyclerView
                                            android:id="@+id/rv_waiting_list"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:descendantFocusability="blocksDescendants" />
                                    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
                                </LinearLayout>

                                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                                    android:id="@+id/srl_update"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent">

                                    <cn.garymb.ygomobile.ui.widget.GridRecyclerView
                                        android:id="@+id/rv_list"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:descendantFocusability="blocksDescendants" />
                                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
                            </LinearLayout>


                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="5dp"
                                android:layout_weight="1"
                                android:background="@drawable/dialogshort"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:background="@drawable/veil2"
                                    android:gravity="center"
                                    android:text="@string/McNews"
                                    android:textColor="@color/holo_green_bright"
                                    android:textSize="8sp"
                                    android:textStyle="bold" />

                                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                                    android:id="@+id/srl_mcNews"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent">

                                    <cn.garymb.ygomobile.ui.widget.GridRecyclerView
                                        android:id="@+id/rv_mcNews_list"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:descendantFocusability="blocksDescendants" />
                                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </ScrollView>

                <RelativeLayout
                    android:id="@+id/rl_chat"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_gravity="bottom"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/list_item_bg"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_message_s"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/mc_chat"
                        android:textColor="@color/holo_green_bright"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/pb_chat_loading"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:layout_toRightOf="@id/tv_message_s"
                        android:visibility="gone" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="@dimen/dp_10"
                        android:layout_toRightOf="@id/pb_chat_loading"
                        android:ellipsize="end"
                        android:lines="1"
                        android:text="@string/login_mycard"
                        android:textColor="@color/holo_orange_bright" />
                </RelativeLayout>
            </LinearLayout>
        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragment_chat_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragment_deck_win_rate_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragment_web_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>
</androidx.appcompat.widget.LinearLayoutCompat>